watch_file pyproject.toml uv.lock
watch_file package-lock.json package.json web/package.json ui-tui/package.json website/package.json apps/shared/package.json apps/desktop/package.json ui-tui/packages/hermes-ink/package.json
watch_file flake.nix flake.lock nix/devShell.nix nix/tui.nix nix/package.nix nix/python.nix

# Only use the Nix flake when nix is actually installed; otherwise direnv
# spams "nix: command not found" on every cd into the project.
has nix && use flake

# Use the project virtualenv (Python 3.12) so `hermes` and `python` resolve
# to the venv instead of the system Python 3.9, which lacks PEP 604 unions.
PATH_add .venv/bin

# Hermes data lives outside ~/Documents (macOS TCC blocks launchd writes there).
# Keep manual `hermes` runs on the same home the gateway agent uses.
export HERMES_HOME="$HOME/.hermes-home"
export XDG_STATE_HOME="$HOME/.hermes-home/xdg-state"